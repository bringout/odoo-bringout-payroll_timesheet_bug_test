<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_payroll_timesheet_bug_wizard_form" model="ir.ui.view">
        <field name="name">payroll.timesheet.bug.wizard.form</field>
        <field name="model">payroll.timesheet.bug.wizard</field>
        <field name="arch" type="xml">
            <form string="Multi-Company Bug Reproductions">
                <div class="alert alert-warning" role="alert">
                    <strong>Deliberately-buggy demo wizard.</strong>
                    Two scenarios that reproduce classic multi-company
                    bugs. Without
                    <code>multi_company_protect_psql_payroll</code> +
                    a user locked via <code>psql_company_lock_id</code>,
                    the bugs manifest silently across all companies.
                    With RLS active for the current user, bugs are
                    contained to the locked company.
                </div>

                <notebook>
                    <page string="A — Count All Employees (read bug)">
                        <p>
                            Buggy query:
                            <code>env['hr.employee'].sudo().search([])</code>.
                            No company filter. A headcount report built
                            like this shows total employees across the
                            whole database to an admin (bug manifests)
                            but only the locked company's headcount to
                            a payroll clerk (RLS contains the bug).
                        </p>
                        <group attrs="{'invisible': [('scenario', '!=', 'count_employees')]}">
                            <field name="employee_count"/>
                            <field name="employee_breakdown" widget="text"/>
                        </group>
                    </page>
                    <page string="B — Tag All Timesheets (write bug)">
                        <p>
                            Buggy call:
                            <code>env['account.analytic.line'].search([]).write(&#123;'name': tag&#125;)</code>.
                            Intended as a benign "mark timesheets as
                            reviewed" routine, but missing the company
                            filter. Admin path overwrites every
                            timesheet's <code>name</code> field — including
                            other companies' — with
                            <code>"BUG-B run by &lt;user&gt;"</code>, producing
                            immediately visible pollution in the
                            Timesheets list. On an RLS-locked session
                            only the locked company's rows are visible
                            to <code>search([])</code>, so only those get
                            tagged — the bug is fully contained.
                        </p>
                        <group string="Result"
                               attrs="{'invisible': [('scenario', '!=', 'tag_timesheets')]}">
                            <field name="lines_affected"/>
                            <field name="before_state" widget="text"/>
                            <field name="after_state" widget="text"/>
                            <field name="error_message" widget="text"
                                   attrs="{'invisible': [('error_message', '=', False)]}"/>
                        </group>
                    </page>
                </notebook>

                <field name="scenario" invisible="1"/>
                <field name="finished" invisible="1"/>

                <footer>
                    <button name="action_run_count_bug"
                            type="object"
                            string="Run: Count Employees (Bug A)"
                            class="btn-primary"/>
                    <button name="action_run_tag_bug"
                            type="object"
                            string="Run: Tag All Timesheets (Bug B)"
                            class="btn-danger"
                            confirm="This will overwrite the 'name' field on every timesheet entry this session can see. Only safe on a test bed."/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_payroll_timesheet_bug_wizard" model="ir.actions.act_window">
        <field name="name">Run Multi-Company Bug Reproductions</field>
        <field name="res_model">payroll.timesheet.bug.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
